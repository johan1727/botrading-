# ── Groq (gratis en console.groq.com — crear 4 cuentas para más límite) ──────
# Cada cuenta da ~14400 req/día con llama-3.1-8b-instant
GROQ_KEY_1=tu_groq_api_key_1
GROQ_KEY_2=tu_groq_api_key_2
GROQ_KEY_3=tu_groq_api_key_3
GROQ_KEY_4=tu_groq_api_key_4

# ── Google Gemini (gratis en aistudio.google.com/apikey) ──────────────────────
# Modelo recomendado: gemini-2.5-flash-lite-preview-06-17 (más rápido y barato)
GEMINI_API_KEY=tu_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite-preview-06-17
MIN_CONFIDENCE=65

# ── KuCoin (crear API en kucoin.com → My Account → API Management) ────────────
# Permisos necesarios: General + Trade (NO activar Withdrawal)
KUCOIN_KEY=tu_kucoin_api_key
KUCOIN_SECRET=tu_kucoin_api_secret
KUCOIN_PASSWORD=tu_kucoin_api_passphrase

# ── Telegram (crear bot con @BotFather en Telegram) ───────────────────────────
# Obtener CHAT_ID: habla con @userinfobot en Telegram
TELEGRAM_TOKEN=tu_telegram_bot_token
TELEGRAM_CHAT_ID=tu_telegram_chat_id

# ── API Server de Freqtrade (panel web en localhost:8080) ──────────────────────
# Deben coincidir con los valores en config.json → api_server
FREQTRADE_API_USER=admin
FREQTRADE_API_PASSWORD=cambia-esta-password
